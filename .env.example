# ---------------------------------------------------------------------------
# voice-intercom receiver configuration
#
# Copy to .env and edit.  The SAME file format works on Termux, Debian,
# Ubuntu and Raspberry Pi OS.  Nothing in here is platform specific except
# the optional AUDIO_* overrides at the bottom, which exist only so you can
# force a backend for testing.
# ---------------------------------------------------------------------------

# --- Identity --------------------------------------------------------------
# Human readable name for this receiver, shown in the controller UI.
RECEIVER_NAME=living-room

# --- Network ---------------------------------------------------------------
# Bind address. 0.0.0.0 listens on every interface including the Tailscale one.
HOST=0.0.0.0
PORT=8080

# --- Authentication --------------------------------------------------------
# Shared secret. The controller sends this as a Bearer token.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED. The receiver refuses to start without it.
AUTH_TOKEN=

# --- TLS (only needed for the Android/browser controller) ------------------
# You probably do NOT need this. See docs/SETUP.md part 3.
#
#   Desktop controller  -> leave blank. It is not a browser, so it grants its
#                          own microphone permission and works over plain HTTP.
#   Android controller  -> required. Browsers refuse microphone access to a
#                          remote http:// origin.
#
# The recommended way to get HTTPS is to let Tailscale terminate it, because
# it renews the certificate automatically:
#
#   tailscale serve --bg --https=443 http://127.0.0.1:8080
#
# Then leave both settings below blank and set HOST=127.0.0.1 above.
#
# The alternative is to hand the receiver its own certificate. Note that
# `tailscale cert` files EXPIRE AFTER 90 DAYS and will not renew themselves:
#
#   tailscale cert my-receiver.tailnet-name.ts.net
TLS_CERT_PATH=
TLS_KEY_PATH=

# --- Audio -----------------------------------------------------------------
# Wire format for push-to-talk. Must match the controller; 16 kHz mono S16LE
# is the Phase 1 default and needs no codec on any platform.
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Close the playback device after this many ms of silence so other apps can
# use it. Set to 0 to hold the device open permanently.
AUDIO_IDLE_TIMEOUT_MS=1500

# Max buffered audio frames before we start dropping. Realtime audio should
# drop rather than lag, so this is deliberately small.
AUDIO_MAX_QUEUE_FRAMES=32

# Force a specific backend instead of auto-detecting the platform.
# Valid: auto | android | alsa | linux | null
# `null` plays nothing but accepts every byte - use it on Windows/macOS/CI.
AUDIO_BACKEND=auto

# Optional device override passed to the backend.
#   alsa   -> aplay -D <value>      e.g. plughw:1,0
#   linux  -> paplay --device=<value>
#   android-> ignored
AUDIO_DEVICE=

# --- Logging ---------------------------------------------------------------
# trace | debug | info | warn | error
LOG_LEVEL=info

# How many log records to keep in memory for GET /api/logs
LOG_BUFFER_SIZE=500

# Optional: also append JSON lines to this file. Blank = stdout only.
LOG_FILE=
